NODE_ENV=development
PORT=3001

# Use memory for zero-setup local development
DB_PROVIDER=memory

# If DB_PROVIDER=mongo, set Mongo URI
MONGO_URI=mongodb://127.0.0.1:27017/lifeline_response

# If DB_PROVIDER=mysql, set MySQL details
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=lifeline_response

JWT_SECRET=change-this-super-secret-key
JWT_EXPIRES_IN=1h
FRONTEND_ORIGIN=http://localhost:8080,http://localhost:5173
